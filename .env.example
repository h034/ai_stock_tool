# PostgreSQL（RenderのDB作成後にURLをコピー）
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Truth Social
TRUTH_SOCIAL_INSTANCE=truthsocial.com
TRUMP_TRUTH_SOCIAL_ID=107780257626128497

# X（旧Twitter）RSS フィードURL（RSS.app などで取得）
X_RSS_URL=https://rss.app/feeds/xxxxxxxx.xml

# LINE Notify（https://notify-bot.line.me/ でトークン発行）
LINE_NOTIFY_TOKEN=

# メール通知（使わない場合は空欄でOK）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=notify@example.com

# スコア通知閾値（この値以上のスコアで通知）
SCORE_THRESHOLD=70

# フェーズB以降（AIスコアリング）
GEMINI_API_KEY=
GROQ_API_KEY=
